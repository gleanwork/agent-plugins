{
  "name": "@gleanwork/agent-plugins",
  "version": "2.2.0",
  "description": "Official Glean agent plugins for AI coding tools.",
  "license": "MIT",
  "author": {
    "name": "Glean",
    "email": "support@glean.com",
    "url": "https://glean.com"
  },
  "type": "module",
  "scripts": {
    "build": "pluginpack build",
    "clean": "pluginpack clean",
    "diff:claude": "pluginpack diff --target claude --against .",
    "diff:cursor": "pluginpack diff --target cursor --against .",
    "prune": "pluginpack prune",
    "test": "npm run diff:claude && npm run diff:cursor",
    "validate": "pluginpack validate --target claude --dir . && pluginpack validate --target cursor --dir .",
    "prebuild": "node scripts/sync-changelog.mjs",
    "release": "release-it"
  },
  "devDependencies": {
    "@gleanwork/pluginpack": "^0.5.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "release-it": "^20.2.0"
  },
  "engines": {
    "node": ">=24"
  }
}
